{"file":"audit-BJjJWZYa.js","mappings":";;;;;;;;;;;;;;;;;;;AAEO,SAAS,cAAc;AAC1B,QAAM,EAAE,KAAA,IAAS,WAAA;AAEjB,SAAO;AAAA,IACH,QAAQ,QAAqF;AACzF,aAAO,KAAkC,UAAU,EAAE,QAAQ;AAAA,IACjE;AAAA,EAAA;AAER;;;;;ACoBY,gBAAA;AAA6B,aAAA;AACzC,UAAM,OAAO,IAAgB,EAAE;AAAG,UAAM,UAAU,IAAI,IAAI;AAAG,UAAM,OAAO,IAAI,CAAC;AAAG,UAAM,QAAQ,IAAI,CAAC;AACrG,UAAM,aAAa,SAAS,MAAM,KAAK,KAAK,MAAM,QAAQ,EAAE,CAAC;;;;;AA9BxC,YAAAA,mBAAA,2BAAA,EAAA,QAAQ,eAAW,MAAA,OAAA,CAAA;;UAMpBC,MAAA,OAAA,GAAO;;;UAAgE,MAAK;AAAA,UAAkB,OAAM;AAAA,QAAA;;MAC/F,WAAAA,MAAA,IAAA,EAAK,WAAM,GAAA;;;;AACVC,sBAAAD,MAAA,IAAA,IAAL,MAAC;+EACkC,EAAE,WAAM,WAAiB,EAAE,QAAgB,WAAW,EAAE,MAAM,sCAC1EE,eAAA,EAAE,MAAM,kDACHA,eAAA,EAAE,QAAQ,qDACAA,eAAA,EAAE,aAAS,GAAA,2CACjBA,eAAA,IAAA,KAAK,EAAE,SAAS,EAAE,eAAA,CAAc;;;;;UAKtEF,MAAA,UAAA,IAAU,GAAA;0HACsBA,MAAA,IAAA,CAAI,uBAAUA,MAAA,UAAA,CAAU,6DACGA,MAAA,IAAA,KAAI,CAAA,IAAA,cAAA,uDAA6FG,sBAAAH,MAAA,IAAA,KAAQA,MAAA,UAAA,CAAU,IAAA,cAAA;;;;;;;;;;;;;;","names":["_ssrRenderComponent","_unref","_ssrRenderList","_ssrInterpolate","_ssrIncludeBooleanAttr"],"sources":["../../../../composables/useAuditApi.ts","../../../../pages/audit.vue"],"sourcesContent":["import type { PaginationParams, PaginatedResponse, AuditLog } from '~/types'\n\nexport function useAuditApi() {\n    const { $api } = useNuxtApp()\n\n    return {\n        findAll(params?: PaginationParams & { userId?: string; resource?: string; action?: string }) {\n            return $api<PaginatedResponse<AuditLog>>('/audit', { params })\n        },\n    }\n}\n","<template>\n  <div>\n    <definePageMeta :layout=\"'dashboard'\" />\n    <div class=\"mb-6\"><h1 class=\"text-2xl font-bold text-white\">Audit Trail</h1><p class=\"text-dark-400 text-sm mt-1\">Track all system actions and changes</p></div>\n    <div class=\"table-container\">\n      <table class=\"data-table\">\n        <thead><tr><th>User</th><th>Action</th><th>Resource</th><th>IP</th><th>Timestamp</th></tr></thead>\n        <tbody>\n          <tr v-if=\"loading\"><td colspan=\"5\" class=\"text-center py-12 text-dark-400\"><Icon name=\"lucide:loader-2\" class=\"w-6 h-6 animate-spin mx-auto\" /></td></tr>\n          <tr v-else-if=\"logs.length === 0\"><td colspan=\"5\" class=\"text-center py-12 text-dark-400\">No audit logs</td></tr>\n          <tr v-for=\"l in logs\" :key=\"l._id\" v-else>\n            <td class=\"text-dark-200 text-sm\">{{ typeof l.userId === 'object' ? (l.userId as any)?.fullName : l.userId }}</td>\n            <td><span class=\"badge-info\">{{ l.action }}</span></td>\n            <td class=\"text-dark-300 text-sm\">{{ l.resource }}</td>\n            <td class=\"text-dark-400 text-xs font-mono\">{{ l.ipAddress || '—' }}</td>\n            <td class=\"text-dark-400 text-xs\">{{ new Date(l.timestamp).toLocaleString() }}</td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n    <div v-if=\"totalPages > 1\" class=\"flex items-center justify-between mt-4\">\n      <p class=\"text-sm text-dark-400\">Page {{ page }} of {{ totalPages }}</p>\n      <div class=\"flex gap-2\"><button @click=\"page--; fetch()\" :disabled=\"page <= 1\" class=\"btn-secondary btn-sm\">Prev</button><button @click=\"page++; fetch()\" :disabled=\"page >= totalPages\" class=\"btn-secondary btn-sm\">Next</button></div>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport type { AuditLog } from '~/types'\ndefinePageMeta({ layout: 'dashboard' })\nconst api = useAuditApi(); const toast = useToast()\nconst logs = ref<AuditLog[]>([]); const loading = ref(true); const page = ref(1); const total = ref(0)\nconst totalPages = computed(() => Math.ceil(total.value / 20))\n\nasync function fetch() { loading.value = true; try { const r = await api.findAll({ page: page.value, limit: 20 }); logs.value = (r as any)?.data || []; total.value = (r as any)?.total || 0 } catch { toast.error('Failed') } finally { loading.value = false } }\nonMounted(fetch)\n</script>\n"],"version":3}