{"file":"edit-BM30Mn2o.js","mappings":";;;;;;;;;;;;;;;;;;;;;;;;;AA+CA,UAAM,QAAQ,SAAA;AACF,mBAAA;AACE,aAAA;AACd,UAAM,SAAS,SAAS,MAAM,MAAM,OAAO,MAAM,MAAM,OAAO,OAAO,KAAK;AAC1E,UAAM,aAAa,IAAgB,EAAE;AACrC,UAAM,SAAS,IAAI,KAAK;AACxB,UAAM,YAAY,IAAI,EAAE;AACxB,UAAM,OAAO,IAAI;AAAA,MACf,MAAM;AAAA,MAAI,aAAa;AAAA,MAAI,OAAO;AAAA,MAAG,gBAAgB;AAAA,MAAG,OAAO;AAAA,MAAG,KAAK;AAAA,MAAI,MAAM;AAAA,MAAI,UAAU;AAAA,MAAI,UAAU;AAAA,MAAM,MAAM,CAAA;AAAA,IAAC,CAC3H;AAED,UAAM,MAAM,KAAK,MAAM,MAAM,CAAC,MAAM;AAClC,UAAI,CAAC,OAAO,MAAO,MAAK,MAAM,OAAO,EAAE,YAAA,EAAc,QAAQ,eAAe,GAAG,EAAE,QAAQ,YAAY,EAAE;AAAA,IACzG,CAAC;;;;;;AA1DoB,YAAAA,mBAAA,2BAAA,EAAA,QAAQ,eAAW,MAAA,OAAA,CAAA;;;QAExB,IAAG;AAAA,QAAY,OAAM;AAAA,MAAA;yBAA/B,CAA8G,GAAAC,QAAAC,UAAA,aAAA;;;cAAtD,MAAK;AAAA,cAAoB,OAAM;AAAA,YAAA;;;cAArCC,YAAiD,iBAAA;AAAA,gBAA3C,MAAK;AAAA,gBAAoB,OAAM;AAAA,cAAA;;;;;;wEAC1CC,MAAA,MAAA,IAAM,iBAAA,aAAA,qLAKKC,cAAA,SAAAD,MAAA,IAAA,EAAK,IAAI,0IACCE,eAAAF,MAAA,IAAA,EAAK,WAAW,0GAEZC,cAAA,SAAAD,MAAA,IAAA,EAAK,KAAK,gHACHC,cAAA,SAAAD,MAAA,IAAA,EAAK,cAAc,sIAG9BC,cAAA,SAAAD,MAAA,IAAA,EAAK,KAAK,mGACnBC,cAAA,SAAAD,MAAA,IAAA,EAAK,GAAG,2HAG5CG,sBAAA,MAAA,QAAAH,MAAA,IAAA,EAAK,QAAQ,IAAbI,gBAAAJ,MAAA,IAAA,EAAK,UAAQ,EAAA,IAAbK,cAAAL,MAAA,IAAA,EAAK,UAAQ,EAAA,CAAA,IAAA,cAAA;AAERM,oBAAAN,MAAA,UAAA,IAAL,MAAC;sCAA8B,SAAO,EAAE,GAAG,IAF3CG,sBAAA,MAAA,QAAAH,MAAA,IAAA,EAAK,QAAQ,IAAbI,gBAAAJ,MAAA,IAAA,EAAK,UAEiC,EAAE,GAAG,IAF3CK,cAAAL,MAAA,IAAA,EAAK,UAEiC,EAAE,GAAG,CAAA,IAAA,cAAA,MAAKE,eAAA,EAAE,IAAI;;kFAGnBD,cAAA,SAAAD,MAAA,IAAA,EAAK,IAAI,mIACSA,MAAA,SAAA,CAAS,sHAE/DG,sBAAA,MAAA,QAAAH,MAAA,IAAA,EAAK,QAAQ,IAAbI,gBAAAJ,MAAA,IAAA,EAAK,UAAQ,IAAA,IAAbA,MAAA,IAAA,EAAK,QAAQ,IAAA,aAAA,sQAKsBA,MAAA,MAAA,CAAM,IAAA,cAAA;UAC7CA,MAAA,MAAA,GAAM;;UAAE,MAAK;AAAA,UAAkB,OAAM;AAAA,QAAA;;;;AAC9C,YAAA,IAAAE,eAAAF,MAAA,MAAA,kBAAwBA,MAAA,MAAA,IAAM,mBAAA,gBAAA,CAAA,WAAA;;QAEzB,IAAG;AAAA,QAAY,OAAM;AAAA,MAAA;yBAA/B,CAAgE,GAAAH,QAAAC,UAAA,aAAA;;;;;8BAAjB,QAAM;AAAA,YAAA;AAAA;;;;;;;;;;;;;;","names":["_ssrRenderComponent","_push","_parent","_createVNode","_unref","_ssrRenderAttr","_ssrInterpolate","_ssrIncludeBooleanAttr","_ssrLooseContain","_ssrLooseEqual","_ssrRenderList"],"sources":["../../../../pages/products/[id]/edit.vue"],"sourcesContent":["<template>\n  <div>\n    <definePageMeta :layout=\"'dashboard'\" />\n    <div class=\"flex items-center gap-3 mb-6\">\n      <NuxtLink to=\"/products\" class=\"btn-ghost btn-sm\"><Icon name=\"lucide:arrow-left\" class=\"w-4 h-4\" /></NuxtLink>\n      <h1 class=\"text-2xl font-bold text-white\">{{ isEdit ? 'Edit Product' : 'New Product' }}</h1>\n    </div>\n    <form @submit.prevent=\"handleSubmit\" class=\"max-w-3xl space-y-6\">\n      <div class=\"card space-y-4\">\n        <h2 class=\"text-lg font-semibold text-white\">Basic Info</h2>\n        <div><label class=\"label\">Name</label><input v-model=\"form.name\" type=\"text\" class=\"input\" required /></div>\n        <div><label class=\"label\">Description</label><textarea v-model=\"form.description\" class=\"input min-h-[100px]\" required /></div>\n        <div class=\"grid grid-cols-2 gap-4\">\n          <div><label class=\"label\">Price (₦)</label><input v-model.number=\"form.price\" type=\"number\" min=\"0\" class=\"input\" required /></div>\n          <div><label class=\"label\">Compare At Price</label><input v-model.number=\"form.compareAtPrice\" type=\"number\" min=\"0\" class=\"input\" /></div>\n        </div>\n        <div class=\"grid grid-cols-2 gap-4\">\n          <div><label class=\"label\">Stock</label><input v-model.number=\"form.stock\" type=\"number\" min=\"0\" class=\"input\" required /></div>\n          <div><label class=\"label\">SKU</label><input v-model=\"form.sku\" type=\"text\" class=\"input\" /></div>\n        </div>\n        <div><label class=\"label\">Category</label>\n          <select v-model=\"form.category\" class=\"input\">\n            <option value=\"\">Select category</option>\n            <option v-for=\"c in categories\" :key=\"c._id\" :value=\"c._id\">{{ c.name }}</option>\n          </select>\n        </div>\n        <div><label class=\"label\">Slug</label><input v-model=\"form.slug\" type=\"text\" class=\"input\" required /></div>\n        <div><label class=\"label\">Tags (comma-separated)</label><input v-model=\"tagsInput\" type=\"text\" class=\"input\" placeholder=\"snack, healthy, popular\" /></div>\n        <div class=\"flex items-center gap-2\">\n          <input v-model=\"form.isActive\" type=\"checkbox\" id=\"isActive\" class=\"rounded bg-dark-800 border-dark-600 text-primary-600\" />\n          <label for=\"isActive\" class=\"text-sm text-dark-300\">Active</label>\n        </div>\n      </div>\n      <div class=\"flex gap-3\">\n        <button type=\"submit\" class=\"btn-primary\" :disabled=\"saving\">\n          <Icon v-if=\"saving\" name=\"lucide:loader-2\" class=\"w-4 h-4 animate-spin\" />\n          {{ saving ? 'Saving...' : (isEdit ? 'Update Product' : 'Create Product') }}\n        </button>\n        <NuxtLink to=\"/products\" class=\"btn-secondary\">Cancel</NuxtLink>\n      </div>\n    </form>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport type { Category } from '~/types'\ndefinePageMeta({ layout: 'dashboard' })\nconst route = useRoute()\nconst api = useProductsApi()\nconst toast = useToast()\nconst isEdit = computed(() => route.params.id && route.params.id !== 'new')\nconst categories = ref<Category[]>([])\nconst saving = ref(false)\nconst tagsInput = ref('')\nconst form = ref({\n  name: '', description: '', price: 0, compareAtPrice: 0, stock: 0, sku: '', slug: '', category: '', isActive: true, tags: [] as string[],\n})\n\nwatch(() => form.value.name, (n) => {\n  if (!isEdit.value) form.value.slug = n.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')\n})\n\nasync function handleSubmit() {\n  saving.value = true\n  form.value.tags = tagsInput.value.split(',').map((t) => t.trim()).filter(Boolean)\n  try {\n    if (isEdit.value) { await api.update(route.params.id as string, form.value); toast.success('Product updated') }\n    else { await api.create(form.value); toast.success('Product created') }\n    navigateTo('/products')\n  } catch (e: any) { toast.error(e?.data?.message || 'Failed to save product') }\n  finally { saving.value = false }\n}\n\nonMounted(async () => {\n  try { categories.value = (await api.getCategories() as any) || [] } catch {}\n  if (isEdit.value) {\n    try {\n      const p = await api.findById(route.params.id as string) as any\n      Object.assign(form.value, { ...p, category: p.category?._id || p.category || '' })\n      tagsInput.value = (p.tags || []).join(', ')\n    } catch { toast.error('Product not found'); navigateTo('/products') }\n  }\n})\n</script>\n"],"version":3}