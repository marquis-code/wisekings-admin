{"file":"index-D-e1nnbx.js","mappings":";;;;;;;;;;;;;;;;;;;;;;;;;AA2DY,mBAAA;AACE,aAAA;AACd,UAAM,WAAW,IAAe,EAAE;AAClC,UAAM,UAAU,IAAI,IAAI;AACxB,UAAM,OAAO,IAAI,CAAC;AAClB,UAAM,QAAQ,IAAI,EAAE;AACpB,UAAM,QAAQ,IAAI,CAAC;AACnB,UAAM,SAAS,IAAI,EAAE;AACrB,UAAM,eAAe,IAAI,EAAE;AAC3B,UAAM,aAAa,SAAS,MAAM,KAAK,KAAK,MAAM,QAAQ,MAAM,KAAK,CAAC;;;;;;AAlEjD,YAAAA,mBAAA,2BAAA,EAAA,QAAQ,eAAW,MAAA,OAAA,CAAA;wUAShBC,MAAA,MAAA,CAAM,iKACLA,MAAA,YAAA,CAAY,oBAAZA,MAAA,YAAA,GAAY,EAAA,kBAAZA,MAAA,YAAA,GAAY,EAAA,CAAA,IAAA,cAAA,qFAAZA,MAAA,YAAA,CAAY,oBAAZA,MAAA,YAAA,GAAY,QAAA,kBAAZA,MAAA,YAAA,GAAY,QAAA,CAAA,IAAA,cAAA,gFAAZA,MAAA,YAAA,CAAY,oBAAZA,MAAA,YAAA,GAAY,SAAA,kBAAZA,MAAA,YAAA,GAAY,SAAA,CAAA,IAAA,cAAA,mFAAZA,MAAA,YAAA,CAAY,oBAAZA,MAAA,YAAA,GAAY,WAAA,kBAAZA,MAAA,YAAA,GAAY,WAAA,CAAA,IAAA,cAAA;UAcjBA,MAAA,OAAA,GAAO;;;UAAgE,MAAK;AAAA,UAAkB,OAAM;AAAA,QAAA;;MAC/F,WAAAA,MAAA,QAAA,EAAS,WAAM,GAAA;;;;AACdC,sBAAAD,MAAA,QAAA,IAAL,MAAC;6DAC+BE,eAAA,EAAE,WAAW,yCAA2CA,eAAA,EAAE,KAAK,uCAC3EA,eAAA,EAAE,aAAa,mEACiBA,eAAA,EAAE,WAAW,oBACnEA,eAAA,EAAE,cAAc,+BACd,EAAE,mBAAe,GAAO,gBAAc,0BAC7BC,eAAA,EAAE,WAAM,WAAA,kBAAkC,EAAE,WAAM,cAAA,iBAAA,eAAA,MAAwDD,eAAA,EAAE,MAAM;;YAGrH,IAAE,aAAe,EAAE,GAAG;AAAA,YAAI,OAAM;AAAA,UAAA;6BAA3C,CAAuH,GAAAE,QAAAC,UAAA,aAAA;;;kBAAnD,MAAK;AAAA,kBAAa,OAAM;AAAA,gBAAA;;;kBAA9BC,YAA8C,iBAAA;AAAA,oBAAxC,MAAK;AAAA,oBAAa,OAAM;AAAA,kBAAA;;;;;;AAC9E,cAAA,EAAE,WAAM,WAAA;;;cAA2F,MAAK;AAAA,cAAe,OAAM;AAAA,YAAA;;;;;AAC7H,cAAA,EAAE,WAAM,UAAA;;;cAAsF,MAAK;AAAA,cAAa,OAAM;AAAA,YAAA;;;;;;;;;;UAOrIN,MAAA,UAAA,IAAU,GAAA;0HACsBA,MAAA,IAAA,CAAI,uBAAUA,MAAA,UAAA,CAAU,6DAEXA,MAAA,IAAA,KAAI,CAAA,IAAA,cAAA,2DACJO,sBAAAP,MAAA,IAAA,KAAQA,MAAA,UAAA,CAAU,IAAA,cAAA;;;;;;;;;;;;;;","names":["_ssrRenderComponent","_unref","_ssrRenderList","_ssrInterpolate","_ssrRenderClass","_push","_parent","_createVNode","_ssrIncludeBooleanAttr"],"sources":["../../../../pages/partners/index.vue"],"sourcesContent":["<template>\n  <div>\n    <definePageMeta :layout=\"'dashboard'\" />\n    <div class=\"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6\">\n      <div>\n        <h1 class=\"text-2xl font-bold text-white\">Partners</h1>\n        <p class=\"text-dark-400 text-sm mt-1\">Manage investor partnerships</p>\n      </div>\n    </div>\n    <div class=\"card mb-6\">\n      <div class=\"flex flex-wrap gap-3\">\n        <input v-model=\"search\" type=\"text\" placeholder=\"Search partners...\" class=\"input max-w-xs\" @input=\"debouncedFetch\" />\n        <select v-model=\"statusFilter\" class=\"input max-w-[160px]\" @change=\"fetchPartners\">\n          <option value=\"\">All Statuses</option>\n          <option value=\"active\">Active</option>\n          <option value=\"pending\">Pending</option>\n          <option value=\"suspended\">Suspended</option>\n        </select>\n      </div>\n    </div>\n    <div class=\"table-container\">\n      <table class=\"data-table\">\n        <thead>\n          <tr><th>Company</th><th>Contact</th><th>Code</th><th>Commission</th><th>Sales</th><th>Status</th><th>Actions</th></tr>\n        </thead>\n        <tbody>\n          <tr v-if=\"loading\"><td colspan=\"7\" class=\"text-center py-12 text-dark-400\"><Icon name=\"lucide:loader-2\" class=\"w-6 h-6 animate-spin mx-auto\" /></td></tr>\n          <tr v-else-if=\"partners.length === 0\"><td colspan=\"7\" class=\"text-center py-12 text-dark-400\">No partners found</td></tr>\n          <tr v-for=\"p in partners\" :key=\"p._id\" v-else>\n            <td><p class=\"font-medium text-white\">{{ p.companyName }}</p><p class=\"text-xs text-dark-400\">{{ p.email }}</p></td>\n            <td class=\"text-dark-200\">{{ p.contactPerson }}</td>\n            <td><code class=\"text-xs bg-dark-800 px-2 py-0.5 rounded\">{{ p.partnerCode }}</code></td>\n            <td>{{ p.commissionRate }}%</td>\n            <td>₦{{ (p.totalSalesValue || 0).toLocaleString() }}</td>\n            <td><span :class=\"p.status === 'active' ? 'badge-success' : p.status === 'suspended' ? 'badge-danger' : 'badge-warning'\">{{ p.status }}</span></td>\n            <td>\n              <div class=\"flex items-center gap-2\">\n                <NuxtLink :to=\"`/partners/${p._id}`\" class=\"btn-ghost btn-sm\"><Icon name=\"lucide:eye\" class=\"w-3.5 h-3.5\" /></NuxtLink>\n                <button v-if=\"p.status === 'pending'\" @click=\"approvePartner(p)\" class=\"btn-ghost btn-sm text-emerald-400\"><Icon name=\"lucide:check\" class=\"w-3.5 h-3.5\" /></button>\n                <button v-if=\"p.status === 'active'\" @click=\"suspendPartner(p)\" class=\"btn-ghost btn-sm text-red-400\"><Icon name=\"lucide:ban\" class=\"w-3.5 h-3.5\" /></button>\n              </div>\n            </td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n    <div v-if=\"totalPages > 1\" class=\"flex items-center justify-between mt-4\">\n      <p class=\"text-sm text-dark-400\">Page {{ page }} of {{ totalPages }}</p>\n      <div class=\"flex gap-2\">\n        <button @click=\"page--; fetchPartners()\" :disabled=\"page <= 1\" class=\"btn-secondary btn-sm\">Previous</button>\n        <button @click=\"page++; fetchPartners()\" :disabled=\"page >= totalPages\" class=\"btn-secondary btn-sm\">Next</button>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport type { Partner } from '~/types'\ndefinePageMeta({ layout: 'dashboard' })\nconst api = usePartnersApi()\nconst toast = useToast()\nconst partners = ref<Partner[]>([])\nconst loading = ref(true)\nconst page = ref(1)\nconst limit = ref(10)\nconst total = ref(0)\nconst search = ref('')\nconst statusFilter = ref('')\nconst totalPages = computed(() => Math.ceil(total.value / limit.value))\nlet debounceTimer: ReturnType<typeof setTimeout>\nfunction debouncedFetch() { clearTimeout(debounceTimer); debounceTimer = setTimeout(() => { page.value = 1; fetchPartners() }, 400) }\n\nasync function fetchPartners() {\n  loading.value = true\n  try {\n    const res = await api.findAll({ page: page.value, limit: limit.value, search: search.value || undefined, status: statusFilter.value || undefined })\n    partners.value = (res as any)?.data || []\n    total.value = (res as any)?.total || 0\n  } catch { toast.error('Failed to load partners') }\n  finally { loading.value = false }\n}\n\nasync function approvePartner(p: Partner) { try { await api.approve(p._id); toast.success('Partner approved'); fetchPartners() } catch { toast.error('Failed') } }\nasync function suspendPartner(p: Partner) { const r = prompt('Reason:'); if (!r) return; try { await api.suspend(p._id, r); toast.success('Suspended'); fetchPartners() } catch { toast.error('Failed') } }\n\nonMounted(fetchPartners)\n</script>\n"],"version":3}